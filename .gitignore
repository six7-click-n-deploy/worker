# =============================================================================
# Worker .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Poetry
# -----------------------------------------------------------------------------
poetry.lock

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Environment Variables / Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
clouds.yaml
secure.yaml

# -----------------------------------------------------------------------------
# Terraform / Packer (lokale Testdateien)
# -----------------------------------------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Packer
packer_cache/
*.pkr.hcl.lock

# -----------------------------------------------------------------------------
# Worker-spezifisch
# -----------------------------------------------------------------------------
/tmp/
worker_repos/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
