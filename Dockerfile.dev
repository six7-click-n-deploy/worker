FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    wget \
    unzip \
    curl \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Terraform
ARG TERRAFORM_VERSION=1.6.6
RUN wget https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip \
    && unzip terraform_${TERRAFORM_VERSION}_linux_amd64.zip \
    && mv terraform /usr/local/bin/ \
    && rm terraform_${TERRAFORM_VERSION}_linux_amd64.zip

# Install Packer
ARG PACKER_VERSION=1.10.0
RUN wget https://releases.hashicorp.com/packer/${PACKER_VERSION}/packer_${PACKER_VERSION}_linux_amd64.zip \
    && unzip packer_${PACKER_VERSION}_linux_amd64.zip \
    && mv packer /usr/local/bin/ \
    && rm packer_${PACKER_VERSION}_linux_amd64.zip

# Install Poetry
RUN curl -sSL https://install.python-poetry.org | python3 - && \
    ln -s /root/.local/bin/poetry /usr/local/bin/poetry

# Copy Poetry files and install dependencies
COPY pyproject.toml ./
COPY poetry.lock ./
RUN poetry install --no-root --no-interaction --no-ansi

# Copy application code
COPY . /app

# Create temp directory for repositories
RUN mkdir -p /tmp/worker_repos

# Hot Reload für Celery Worker im app/-Verzeichnis
WORKDIR /app
CMD ["poetry", "run", "watchmedo", "auto-restart", "--directory=app/", "--pattern=*.py", "--recursive", "--", "celery", "-A", "app.celery_app", "worker", "--loglevel=info", "--autoscale=2,20", "-E", "-Q", "deployment-*,default", "--prefetch-multiplier=1"]
